	const boardSelect = document.getElementById('boardSelect');
const classSelect = document.getElementById('classSelect');
const subjectSelect = document.getElementById('subjectSelect');
const typeSelect = document.getElementById('typeSelect');
const chapterSelect = document.getElementById('chapterSelect');
const levelSelect = document.getElementById('levelSelect');
const itemSelect = document.getElementById('itemSelect');
const viewer = document.getElementById('viewer');

    function resetSelect(selectEl, placeholderText, disable = false) {
      selectEl.innerHTML = `<option value="">${placeholderText}</option>`;
      selectEl.disabled = disable;
    }
    function fillSelect(selectEl, items) {
      items.forEach(v => { selectEl.innerHTML += `<option value="${v}">${v}</option>`; });
      selectEl.disabled = false;
    }
    
function getKeys(obj) { return obj ? Object.keys(obj) : []; }

const classLabel = document.getElementById('classLabel');

boardSelect.addEventListener('change', () => {
  const board = boardSelect.value;

  resetSelect(classSelect, 'Select Class', true);
  resetSelect(subjectSelect, 'Select Subject', true);
  resetSelect(typeSelect, 'Select Type', true);
  resetSelect(chapterSelect, 'Select Chapter', true);
  resetSelect(levelSelect, 'Select Level', true);
  resetSelect(itemSelect, 'Select Topic', true);

  levelSelect.style.display = "none";
  itemSelect.style.display = "none";
  document.getElementById("levelLabel").style.display = "none";

 // Allow IIT-JEE & NEET even if not in catalog
if (!catalog[board] && board !== "IIT-JEE" && board !== "NEET") return;

  // ✅ HIDE CLASS FOR JEE/NEET
  if (board === "IIT-JEE" || board === "NEET") {

    classSelect.style.display = "none";
    classLabel.style.display = "none";   // ⭐ IMPORTANT FIX

    const subjects = board === "NEET"
      ? ["Physics", "Chemistry", "Biology"]
      : ["Physics", "Chemistry", "Math"];

    fillSelect(subjectSelect, subjects);

  } else {

    classSelect.style.display = "inline-block";
    classLabel.style.display = "inline-block"; // ⭐ SHOW AGAIN

    fillSelect(classSelect, Object.keys(catalog[board]));
  }
});






classSelect.addEventListener('change', () => {
  const board = boardSelect.value;
  const cls = classSelect.value;

  resetSelect(subjectSelect, 'Select Subject', true);
  resetSelect(typeSelect, 'Select Type', true);
  resetSelect(chapterSelect, 'Select Chapter', true);
  resetSelect(itemSelect, 'Select Topic', true);

  if (!catalog[board]?.[cls]) return;

  const seniorClasses = ["Class 11", "Class 12", "IIT-JEE", "NEET"];

  let subjects = [];

  if (seniorClasses.includes(cls)) {
    subjects = ["Physics", "Chemistry", "Math","Biology"];
  } else {
    subjects = ["Science", "Math", "SST", "English"];
  }

  // ✅ FILTER ONLY AVAILABLE SUBJECTS
  const availableSubjects = subjects.filter(sub =>
    catalog[board][cls][sub]
  );

  fillSelect(subjectSelect, availableSubjects);
});




subjectSelect.addEventListener('change', () => {
  const board = boardSelect.value;
  const cls = classSelect.value;
  const subj = subjectSelect.value;

  resetSelect(typeSelect, 'Select Type', true);
  resetSelect(chapterSelect, 'Select Chapter', true);
  resetSelect(itemSelect, 'Select Topic', true);

  let data;

  if (board === "IIT-JEE" || board === "NEET") {
    data = catalog[board]?.[subj]; // no class
  } else {
    data = catalog[board]?.[cls]?.[subj];
  }

  if (!data) return;

  fillSelect(typeSelect, Object.keys(data));
});





typeSelect.addEventListener('change', () => {
  const board = boardSelect.value;
  const cls = classSelect.value;
  const subj = subjectSelect.value;
  const type = typeSelect.value;

  resetSelect(chapterSelect, 'Select Chapter', true);
  resetSelect(levelSelect, 'Select Level', true);
  resetSelect(itemSelect, 'Select Topic', true);

  levelSelect.style.display = "none";
  itemSelect.style.display = "none";
  document.getElementById("levelLabel").style.display = "none";

  let base;

  if (board === "IIT-JEE" || board === "NEET") {
    base = catalog[board]?.[subj];
  } else {
    base = catalog[board]?.[cls]?.[subj];
  }

  if (!base?.[type]) return;

  fillSelect(chapterSelect, Object.keys(base[type]));
});



chapterSelect.addEventListener('change', () => {
  const board = boardSelect.value;
  const cls = classSelect.value;
  const subj = subjectSelect.value;
  const type = typeSelect.value;
  const chap = chapterSelect.value;

  let base;

  if (board === "IIT-JEE" || board === "NEET") {
    base = catalog[board]?.[subj];
  } else {
    base = catalog[board]?.[cls]?.[subj];
  }

  if (!base?.[type]?.[chap]) return;

  const data = base[type][chap];

  if (type === "Practice Test") {
    document.getElementById("levelLabel").style.display = "inline-block";
    levelSelect.style.display = "inline-block";

    fillSelect(levelSelect, Object.keys(data));
  } else if (type === "Study Material") {
    const firstKey = Object.keys(data)[0];
    viewer.src = data[firstKey];
  }
});



levelSelect.addEventListener('change', () => {
  const board = boardSelect.value;
  const cls = classSelect.value;
  const subj = subjectSelect.value;
  const type = typeSelect.value;
  const chap = chapterSelect.value;
  const level = levelSelect.value;

  let base;

  if (board === "IIT-JEE" || board === "NEET") {
    base = catalog[board]?.[subj];
  } else {
    base = catalog[board]?.[cls]?.[subj];
  }

  const data = base?.[type]?.[chap]?.[level];

  if (!data) return;

  resetSelect(itemSelect, 'Select Test', true);
  itemSelect.style.display = "inline-block";

  fillSelect(itemSelect, Object.keys(data));
});


 itemSelect.addEventListener('change', () => {
  const board = boardSelect.value;
  const cls = classSelect.value;
  const subj = subjectSelect.value;
  const type = typeSelect.value;
  const chap = chapterSelect.value;
  const level = levelSelect.value;
  const item = itemSelect.value;

  let base;

  if (board === "IIT-JEE" || board === "NEET") {
    base = catalog[board]?.[subj];
  } else {
    base = catalog[board]?.[cls]?.[subj];
  }

  const url = base?.[type]?.[chap]?.[level]?.[item];

  if (!url) return;

  viewer.src = url;
});


















   










/* === MOBILE AUTO HEADER SCROLL === */
if(window.innerWidth<=600){
 const bar=document.getElementById("headerBar");
 let direction=1;
 setInterval(()=>{
  if(bar.scrollWidth>bar.clientWidth){
   if(bar.scrollLeft+bar.clientWidth>=bar.scrollWidth-5)direction=-1;
   else if(bar.scrollLeft<=5)direction=1;
   bar.scrollBy({left:50*direction,behavior:"smooth"});
  }
 },3000);
}
